/**
 * Core Philosophy: This ruleset enforces a strict user-ownership security model.
 * All user-generated data is private and can only be accessed by the user who
 * created it. This is achieved by nesting all user-specific data within a
 * dedicated user path.
 *
 * Data Structure: The data is organized hierarchically under a top-level `users`
 * collection. Each user's data, including their profile, resumes, and career
 * roadmaps, is stored in subcollections under their unique document path:
 * `/users/{userId}/{subcollection}/{documentId}`. This structure ensures that
 * authorization can be determined simply by checking the path.
 *
 * Key Security Decisions:
 * - Default Deny: All access is denied by default. Rules explicitly grant
 *   permissions on a case-by-case basis.
 * - No User Enumeration: Listing documents in the top-level `/users` collection
 *   is explicitly forbidden to prevent attackers from discovering user IDs.
 * - Path-Based Authorization: All security decisions for user data are based on
 *   the `{userId}` wildcard in the document path, ensuring that a user can only
 *   ever access data within their own data tree.
 * - Relational Integrity: On document creation, rules validate that any internal
 *   `userId` or `id` field matches the corresponding ID in the path, ensuring
 *   data consistency. These fields are enforced as immutable on update.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to improve readability and maintainability.

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the given userId.
     * This is the primary function for enforcing user ownership.
     * @param userId The user ID from the document path.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks for ownership on an existing document. Used for update and delete
     * operations to prevent acting on non-existent data.
     * @param userId The user ID from the document path.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && exists(/databases/$(database)/documents/users/$(userId));
    }

    /**
     * @description Governs access to a user's own profile document.
     * @path /users/{userId}
     * @allow A signed-in user creating their own user document: `(create)` with `auth.uid` matching `{userId}`.
     * @deny A signed-in user trying to read another user's profile: `(get)` on `/users/anotherUser`.
     * @principle Enforces self-creation and strict ownership of user profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Prevents user enumeration
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Secures a user's private ATS analysis documents.
       * @path /users/{userId}/atsAnalyses/{atsAnalysisId}
       * @allow The owner creating or reading their own ATS analysis: `(create, get)` on `/users/{auth.uid}/atsAnalyses/...`.
       * @deny Another user trying to list ATS analyses: `(list)` on `/users/anotherUser/atsAnalyses`.
       * @principle Restricts access to a user's own data tree and validates relational integrity.
       */
      match /atsAnalyses/{atsAnalysisId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Secures a user's private resume documents.
       * @path /users/{userId}/resumes/{resumeId}
       * @allow The owner creating or reading their own resume: `(create, get)` on `/users/{auth.uid}/resumes/...`.
       * @deny Another user trying to update a resume: `(update)` on `/users/anotherUser/resumes/resume_abc`.
       * @principle Restricts access to a user's own data tree and validates relational integrity.
       */
      match /resumes/{resumeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Secures a user's private career roadmap documents.
       * @path /users/{userId}/careerRoadmaps/{careerRoadmapId}
       * @allow The owner creating or reading their own roadmap: `(create, get)` on `/users/{auth.uid}/careerRoadmaps/...`.
       * @deny Another user trying to delete a roadmap: `(delete)` on `/users/anotherUser/careerRoadmaps/roadmap_abc`.
       * @principle Restricts access to a user's own data tree and validates relational integrity.
       */
      match /careerRoadmaps/{careerRoadmapId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Secures the stages within a user's private career roadmap.
         * @path /users/{userId}/careerRoadmaps/{careerRoadmapId}/roadmapStages/{roadmapStageId}
         * @allow The owner of the parent roadmap creating a stage: `(create)` on `/users/{auth.uid}/...`.
         * @deny Another user trying to read a roadmap stage: `(get)` on `/users/anotherUser/...`.
         * @principle Enforces ownership based on the parent collection's path.
         */
        match /roadmapStages/{roadmapStageId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId);
          allow update: if isExistingOwner(userId);
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Secures a user's private social account links.
       * @path /users/{userId}/socialAccounts/{socialAccountId}
       * @allow The owner creating or listing their own social accounts: `(create, list)` on `/users/{auth.uid}/socialAccounts`.
       * @deny Another user trying to update a social account: `(update)` on `/users/anotherUser/socialAccounts/acc_abc`.
       * @principle Restricts access to a user's own data tree and validates relational integrity.
       */
      match /socialAccounts/{socialAccountId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Secures a user's private job recommendations.
       * @path /users/{userId}/jobRecommendations/{jobRecommendationId}
       * @allow The owner creating or reading their job recommendations: `(create, get)` on `/users/{auth.uid}/jobRecommendations/...`.
       * @deny Another user trying to delete a job recommendation: `(delete)` on `/users/anotherUser/jobRecommendations/job_abc`.
       * @principle Restricts access to a user's own data tree and validates relational integrity.
       */
      match /jobRecommendations/{jobRecommendationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Secures a user's private job application records.
       * @path /users/{userId}/applications/{applicationId}
       * @allow The owner creating or listing their own job applications: `(create, list)` on `/users/{auth.uid}/applications`.
       * @deny Another user trying to read a job application: `(get)` on `/users/anotherUser/applications/app_abc`.
       * @principle Restricts access to a user's own data tree and validates relational integrity.
       */
      match /applications/{applicationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}
    